# Postgres
POSTGRES_PASSWORD=jwrag_dev
POSTGRES_PORT=5432

# ===========================================================================
# Ollama — TWO modes:
#   1. Use your host Ollama (DEFAULT):
#        OLLAMA_HOST=http://host.docker.internal:11434
#      This connects to whatever Ollama is already running on your machine.
#      You manage models with `ollama pull ...` directly.
#
#   2. Use the bundled Ollama inside Docker (only if you don't have one):
#        - Set OLLAMA_HOST=http://ollama:11434
#        - Start with: docker compose up -d --profile bundled-ollama
#      The ollama-init service will auto-pull the models below on first start.
# ===========================================================================
OLLAMA_HOST=http://host.docker.internal:11434
OLLAMA_PORT=11434

# Models — adjust to what you have. Common options:
#   LLM:        qwen2.5:latest, llama3.2:3b, llama3.1:8b, mistral:7b, phi3:mini
#   Embeddings: nomic-embed-text (768 dims), bge-m3 (1024 dims)
#
# If you change OLLAMA_EMBED_MODEL, also update vector(768) in scripts/init_db.sql
OLLAMA_LLM_MODEL=qwen2.5:latest
OLLAMA_EMBED_MODEL=nomic-embed-text

# Optional: pull an additional LLM during bundled-ollama init
# EXTRA_LLM_MODEL=llama3.1:8b

# Backend
BACKEND_PORT=5000

# Frontend
FRONTEND_PORT=8080
